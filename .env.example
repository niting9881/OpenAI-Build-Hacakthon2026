# Deterministic mode is reproducible and requires no credentials.
OPSPILOT_REASONING_MODE=deterministic

# To validate live GPT-5.6, copy this file to .env.local and set a
# restricted server-side key. Never commit the populated .env.local file.
OPENAI_API_KEY=your-server-side-openai-key
OPENAI_MODEL=gpt-5.6

# Optional local SQLite path.
OPSPILOT_DB_PATH=work/opspilot-demo.db
